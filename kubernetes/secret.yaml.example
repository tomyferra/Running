# Copy this file to secret.yaml, fill in base64-encoded values, then apply.
# Generate values: echo -n 'your-value' | base64
#
# secret.yaml is in .gitignore — never commit real credentials.

apiVersion: v1
kind: Secret
metadata:
  name: garmin-credentials
  namespace: default
  labels:
    app: garmin-api
type: Opaque
data:
  GARMIN_EMAIL: <base64-encoded-email>
  GARMIN_PASSWORD: <base64-encoded-password>
